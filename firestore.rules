rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper checks
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'admin' || getUserData().role == 'Administrador');
    }

    function isStore() {
      return isAuthenticated() && (getUserData().role == 'store' || getUserData().role == 'Tienda');
    }

    function isCourier() {
      return isAuthenticated() && (getUserData().role == 'courier' || getUserData().role == 'Motorista');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Stores collection rules
    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || (isStore() && (request.auth.uid == storeId || getUserData().storeId == storeId));
      allow delete: if isAdmin();
    }

    // Orders collection rules
    match /orders/{orderId} {
      allow read: if isAdmin() || isCourier() || (isStore() && (resource == null || resource.data.storeId == request.auth.uid || resource.data.storeId == getUserData().storeId));
      allow create: if isAdmin() || (isStore() && (request.resource.data.storeId == request.auth.uid || request.resource.data.storeId == getUserData().storeId));
      allow update: if isAdmin() || isCourier() || (isStore() && (resource.data.storeId == request.auth.uid || resource.data.storeId == getUserData().storeId));
      allow delete: if isAdmin();

      // Subcollection order events
      match /events/{eventId} {
        allow read, create: if isAuthenticated();
      }
    }

    // Courier Profiles rules
    match /couriers/{courierId} {
      allow read: if isAuthenticated() && (request.auth.uid == courierId || resource.data.userUid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Courier Locations rules
    match /courier_locations/{locationId} {
      allow create: if isCourier() && request.resource.data.courierUid == request.auth.uid;
      allow read: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Courier Routes rules
    match /courier_routes/{routeId} {
      allow create, update: if isCourier() && request.resource.data.courierUid == request.auth.uid;
      allow read: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Settings rules
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
